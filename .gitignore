# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Production build
build/

# SQLite databases — runtime data, never committed.
# Each server has its own data.db managed by the migration system.
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak.*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# WhatsApp payment screenshots — saved by the webhook on the server,
# served via /api/screenshots. Contains sensitive financial data.
/screenshots/

# Playwright MCP test artifacts — logs + page snapshots from the
# Claude Code Playwright plugin. Never needed in the repo.
.playwright-mcp/

# Temporary reference images — screenshots, mockups, debug captures
# saved at the repo root during development. Source assets that
# belong in the repo (logo, icons) live in public/ and are tracked.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp

# TypeScript build info — generated, not source
tsconfig.tsbuildinfo

# PM2 runtime files
.pm2/
ecosystem.config.*
